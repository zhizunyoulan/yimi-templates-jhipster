package ${currentClass.packageName};

#if($anyFieldIsBigDecimal)## A
import java.math.BigDecimal;
#end## A
#if($anyFieldIsInstant)## A
import java.time.Instant;
#end## A
#if($anyFieldIsLocalDate)## A
import java.time.LocalDate;
#end## A
#if($anyFieldIsZonedDateTime)## A
import java.time.ZonedDateTime;
#end## A
#if($anyFieldIsLocalTime)## A
import java.time.LocalTime;
#end## A
#if($anyFieldIsDuration)## A
import java.time.Duration;
#end## A
#if($anyFieldIsUUID || $otherEntityPrimaryKeyTypesIncludesUUID)## A
import java.util.UUID;
#end## A
import java.util.function.BiFunction;

import org.springframework.stereotype.Service;

import ${mainModelClass.qualifiedName};
#foreach($enumField in $uniqueEnums)## A
import ${groupId}.domain.enumeration.${enumField.fieldType};
#end## A
#if($packageName != $entityAbsolutePackage)## A
import ${packageName}.repository.rowmapper.ColumnConverter;
#end## A

import io.r2dbc.spi.Row;

/**
 * Converter between {@link Row} to {@link ${persistClass}}, with proper type conversions.
 */
@Service
public class ${currentClass.simpleName} implements BiFunction<Row, String, ${persistClass}> {
    private final ColumnConverter converter;
    public ${entityClass}RowMapper(ColumnConverter converter) {
        this.converter = converter;
    }

    /**
     * Take a {@link Row} and a column prefix, and extract all the fields.
     * @return the {@link ${persistClass}} stored in the database.
     */
    @Override
    public ${persistClass} apply(Row row, String prefix) {
        ${persistClass} entity = new ${persistClass}();
#foreach($field in $fields)## A
#if(!$field.transient)## A-1
#set($fieldType = $field.fieldType)## A-1-1
#if($field.blobContentTypeText)## A-1-1-1
#set($fieldType = "String")## A-1-1-1
#end## A-1-1-1
#if($field.fieldTypeBytes && !$field.blobContentTypeText)## A-1-1
        entity.${field.propertyConsumerName}ContentType(converter.fromRow(row, prefix + "_${field.fieldNameAsDatabaseColumn}_content_type", String.class));
#end## A-1-1
        entity.${field.propertyConsumerName}(converter.fromRow(row, prefix + "_${field.fieldNameAsDatabaseColumn}", ${fieldType}.class));
#end## A-1
#end## A
#foreach($rel in $reactiveRegularEagerRelations)## A
        entity.${rel.propertyConsumerName}Id(converter.fromRow(row, prefix + "_${rel.joinColumnNames[0]}", ${rel.otherEntity.primaryKey.type}.class));
#end## A
        return entity;
    }

}
