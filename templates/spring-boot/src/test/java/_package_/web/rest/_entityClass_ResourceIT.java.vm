  #if(($primaryKey.typeUUID && $databaseTypeSql) || !$primaryKey.autoGenerate)## A-1
        inserted${persistClass} = ${entityInstance}Repository.${saveMethod}(${persistInstance})${callBlock};
  #else## A-1
        ${persistInstance}.${primaryKey.propertyConsumerName}(#if($primaryKey.typeUUID)UUID.randomUUID()#elseif($primaryKey.typeLong)1L#elseif($primaryKey.typeInteger)1#else"existing_id"#end);
