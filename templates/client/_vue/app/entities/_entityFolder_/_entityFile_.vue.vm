<template>
    <div>
        <h2 id="page-heading" data-cy="${entityClass}Heading">
            <span v-text="t$('${global.appName}.${mainModel.camelCaseModelName}.home.title')" id="${entityFileName}-heading">${entityClassPluralHumanized}</span>
            <div class="d-flex justify-content-end">
                <button class="btn btn-info mr-2" @click="handleSyncList" :disabled="isFetching">
                    <font-awesome-icon icon="sync" :spin="isFetching"></font-awesome-icon> <span v-text="t$('${global.appName}.${mainModel.camelCaseModelName}.home.refreshListLabel')">Refresh List</span>
                </button>
#if(!$readOnly)## A
                <router-link :to="{name: '${entityAngularName}Create'}" custom v-slot="{ navigate }">
                    <button @click="navigate" id="jh-create-entity" data-cy="entityCreateButton" class="btn btn-primary jh-create-entity create-${entityUrl}">
                        <font-awesome-icon icon="plus"></font-awesome-icon>
                        <span  v-text="t$('${global.appName}.${mainModel.camelCaseModelName}.home.createLabel')">
                            Create a new ${entityClassHumanized}
                        </span>
                    </button>
                </router-link>
#end## A
            </div>
        </h2>
#if($searchEngineAny)## A
        <div class="row">
            <div class="col-sm-12">
                <form name="searchForm" class="form-inline" @submit.prevent="search(currentSearch)">
                    <div class="input-group w-100 mt-3">
                        <input type="text" class="form-control" name="currentSearch" id="currentSearch"
                            :placeholder="t$('${global.appName}.${mainModel.camelCaseModelName}.home.search')"
                            v-model="currentSearch" />
                        <button type="button" id="launch-search" class="btn btn-primary" @click="search(currentSearch)">
                            <font-awesome-icon icon="search"></font-awesome-icon>
                        </button>
                        <button type="button" id="clear-search" class="btn btn-secondary" @click="clear()"
                            v-if="currentSearch">
                            <font-awesome-icon icon="trash"></font-awesome-icon>
                        </button>
                    </div>
                </form>
            </div>
        </div>
#end## A
        <br/>
        <div class="alert alert-warning" v-if="!isFetching && ${entityInstancePlural} && ${entityInstancePlural}.length === 0">
            <span v-text="t$('${global.appName}.${mainModel.camelCaseModelName}.home.notFound')">No ${entityInstancePlural} found</span>
        </div>
        <div class="table-responsive" v-if="${entityInstancePlural} && ${entityInstancePlural}.length > 0">
            <table class="table table-striped" aria-describedby="${entityInstancePlural}">
                <thead>
                 <tr>
                    <th scope="row"#if(!$paginationNo) @click="changeOrder('${primaryKey.name}')"#end><span v-text="t$('global.field.id')">${primaryKey.nameCapitalized}</span>#if(!$paginationNo) <jhi-sort-indicator :current-order="propOrder" :reverse="reverse" :field-name="'id'"></jhi-sort-indicator>#end</th>
#foreach($field in $fields)## A
#if(!$field.id)## A-1
                    <th scope="row"#if(!$paginationNo) @click="changeOrder('${field.fieldName}')"#end><span v-text="t$('${i18nKeyPrefix}.${field.fieldName}')">${field.fieldNameHumanized}</span>#if(!$paginationNo) <jhi-sort-indicator :current-order="propOrder" :reverse="reverse" :field-name="'${field.fieldName}'"></jhi-sort-indicator>#end</th>
#end## A-1
#end## A
#foreach($relationship in $relationships)## A
#if($relationship.persistableRelationship && ($paginationNo || !$relationship.collection))## A-1
#set($fieldName = "." + $relationship.otherEntityField)## A-1-1
                    <th scope="row"#if(!$paginationNo) @click="changeOrder('${relationship.relationshipName}${fieldName}')"#end><span v-text="t$('${i18nKeyPrefix}.${relationship.relationshipName}')">${relationship.relationshipNameHumanized}</span>#if(!$paginationNo) <jhi-sort-indicator :current-order="propOrder" :reverse="reverse" :field-name="'${relationship.relationshipName}${fieldName}'"></jhi-sort-indicator>#end</th>
#end## A-1
#end## A
                    <th scope="row"></th>
                 </tr>
                </thead>
                <tbody>
                <tr v-for="${entityInstance} in ${entityInstancePlural}"
                    :key="${entityInstance}.${primaryKey.name}" data-cy="entityTable">
                    <td>
                        <router-link :to="{name: '${entityAngularName}View', params: {${entityInstance}Id: ${entityInstance}.${primaryKey.name}}}">{{${entityInstance}.${primaryKey.name}}}</router-link>
                    </td>
#foreach($field in $fields)## A
#if(!$field.id)## A-1
#set($fieldName = $field.fieldName)## A-1-1
#set($fieldType = $field.fieldType)## A-1-1
#if($field.fieldTypeBinary && $field.blobContentTypeImage)## A-1-1-1
                    <td>
                        <a v-if="${entityInstance}.${fieldName}" @click="openFile(${entityInstance}.${fieldName}ContentType, ${entityInstance}.${fieldName})">
                            <img :src="'data:' + ${entityInstance}.${fieldName}ContentType + ';base64,' + ${entityInstance}.${fieldName}" style="max-height: 30px;" alt="${entityInstance}"/>
                        </a>
                        <span v-if="${entityInstance}.${fieldName}">{{${entityInstance}.${fieldName}ContentType}}, {{byteSize(${entityInstance}.${fieldName})}}</span>
                    </td>
#elseif($field.fieldTypeBinary && $field.blobContentTypeAny)## A-1-1-1
                    <td>
                        <a v-if="${entityInstance}.${fieldName}" @click="openFile(${entityInstance}.${fieldName}ContentType, ${entityInstance}.${fieldName})" v-text="t$('entity.action.open')">open</a>
                        <span v-if="${entityInstance}.${fieldName}">{{${entityInstance}.${fieldName}ContentType}}, {{byteSize(${entityInstance}.${fieldName})}}</span>
                    </td>
#elseif($field.fieldIsEnum)## A-1-1-1
                    <td v-text="t$('${frontendAppName}.${fieldType}.' + ${entityInstance}.${fieldName})">{{${entityInstance}.${fieldName}}}</td>
#elseif($field.fieldTypeDuration)## A-1-1-1
                    <td>{{formatDuration(${entityInstance}.${fieldName})}}</td>
#elseif($field.fieldTypeTimed)## A-1-1-1
                    <td>{{formatDateShort(${entityInstance}.${fieldName}) || ''}}</td>
#else## A-1-1-1
                    <td>{{${entityInstance}.${fieldName}}}</td>
#end## A-1-1-1
#end## A-1
#end## A
#foreach($relationship in $relationships)## A
#if(!$relationship.otherEntity.embedded && $relationship.persistableRelationship && ($paginationNo || !$relationship.collection))## A-1
#set($relationshipFieldName = $relationship.relationshipFieldName)## A-1-1
#set($relationshipFieldNamePlural = $relationship.relationshipFieldNamePlural)## A-1-1
#set($otherEntityName = $relationship.otherEntityName)## A-1-1
#set($otherEntityField = $relationship.otherEntityField)## A-1-1
#set($otherEntityAngularName = $relationship.otherEntity.entityAngularName)## A-1-1
                    <td>
#if($relationship.otherEntityUser)## A-1-1-1
#if($relationship.relationshipManyToMany)## A-1-1-1-1
                        <span v-for="(${relationshipFieldName}, i) in ${entityInstance}.${relationshipFieldNamePlural}" :key="${relationshipFieldName}.${primaryKey.name}">{{i > 0 ? ', ' : ''}}
                            {{${relationshipFieldName}.${otherEntityField}}}
                        </span>
#else## A-1-1-1-1
                        {{${entityInstance}.${relationshipFieldName} ? ${entityInstance}.${relationshipFieldName}.${otherEntityField} : ''}}
#end## A-1-1-1-1
#else## A-1-1-1
#if($relationship.relationshipManyToMany)## A-1-1-1-1
                        <span v-for="(${relationshipFieldName}, i) in ${entityInstance}.${relationshipFieldNamePlural}" :key="${relationshipFieldName}.${primaryKey.name}">{{i > 0 ? ', ' : ''}}
                            <router-link class="form-control-static" :to="{name: '${otherEntityAngularName}View', params: {${otherEntityName}Id: ${relationshipFieldName}.${relationship.otherEntity.primaryKey.name}}}">{{${relationshipFieldName}.${otherEntityField}}}</router-link>
                        </span>
#else## A-1-1-1-1
                        <div v-if="${entityInstance}.${relationshipFieldName}">
                            <router-link :to="{name: '${otherEntityAngularName}View', params: {${otherEntityName}Id: ${entityInstance}.${relationshipFieldName}.${relationship.otherEntity.primaryKey.name}}}">{{${entityInstance}.${relationshipFieldName}.${otherEntityField}}}</router-link>
                        </div>
#end## A-1-1-1-1
#end## A-1-1-1
                    </td>
#end## A-1
#end## A
                    <td class="text-right">
                        <div class="btn-group">
#if($authenticationTypeSession)## A-1
                            <router-link :to="{name: '${entityAngularName}View', params: {${entityInstance}Id: ${entityInstance}.${primaryKey.name}}}" class="btn btn-info btn-sm details" data-cy="entityDetailsButton">
#else## A-1
                            <router-link :to="{name: '${entityAngularName}View', params: {${entityInstance}Id: ${entityInstance}.${primaryKey.name}}}" custom v-slot="{ navigate }">
                                <button @click="navigate" class="btn btn-info btn-sm details" data-cy="entityDetailsButton">
#end## A-1
                                    <font-awesome-icon icon="eye"></font-awesome-icon>
                                    <span class="d-none d-md-inline" v-text="t$('entity.action.view')">View</span>
#if(!$authenticationTypeSession)## A-1
                                </button>
#end## A-1
                            </router-link>
#if(!$readOnly)## A-1
#if($authenticationTypeSession)## A-1-1
                            <router-link :to="{name: '${entityAngularName}Edit', params: {${entityInstance}Id: ${entityInstance}.${primaryKey.name}}}" class="btn btn-primary btn-sm edit" data-cy="entityEditButton">
#else## A-1-1
                            <router-link :to="{name: '${entityAngularName}Edit', params: {${entityInstance}Id: ${entityInstance}.${primaryKey.name}}}" custom v-slot="{ navigate }">
                                <button @click="navigate" class="btn btn-primary btn-sm edit" data-cy="entityEditButton">
#end## A-1-1
                                    <font-awesome-icon icon="pencil-alt"></font-awesome-icon>
                                    <span class="d-none d-md-inline" v-text="t$('entity.action.edit')">Edit</span>
#if(!$authenticationTypeSession)## A-1-1
                                </button>
#end## A-1-1
                            </router-link>
                            <b-button @click="prepareRemove(${entityInstance})"
                                   variant="danger"
                                   class="btn btn-sm"
                                   data-cy="entityDeleteButton"
                                   v-b-modal.removeEntity>
                                <font-awesome-icon icon="times"></font-awesome-icon>
                                <span class="d-none d-md-inline" v-text="t$('entity.action.delete')">Delete</span>
                            </b-button>
#end## A-1
                        </div>
                    </td>
                </tr>
                </tbody>
#if(!$databaseTypeCassandra)## A
#if($paginationInfiniteScroll)## A-1
                <span ref="infiniteScrollEl"></span>
#end## A-1
#end## A
            </table>
        </div>
#if(!$readOnly)## A
        <b-modal ref="removeEntity" id="removeEntity" >
            <template #modal-title>
                <span id="${global.appName}.${mainModel.camelCaseModelName}.delete.question" data-cy="${entityInstance}DeleteDialogHeading" v-text="t$('entity.delete.title')">Confirm delete operation</span>
            </template>
            <div class="modal-body">
                <p id="${jhiPrefixDashed}-delete-${entityInstance}-heading" v-text="t$('${global.appName}.${mainModel.camelCaseModelName}.delete.question', {'id': removeId})">Are you sure you want to delete this ${entityClassHumanized}?</p>
            </div>
            <template #modal-footer>
                <div>
                    <button type="button" class="btn btn-secondary" v-text="t$('entity.action.cancel')" @click="closeDialog()">Cancel</button>
                    <button type="button" class="btn btn-primary" id="${jhiPrefixDashed}-confirm-delete-${entityInstance}" data-cy="entityConfirmDeleteButton" v-text="t$('entity.action.delete')" @click="remove${entityAngularName}()">Delete</button>
                </div>
            </template>
        </b-modal>
#end## A
#if(!$databaseTypeCassandra)## A
#if($paginationPagination)## A-1
        <div v-show="${entityInstancePlural} && ${entityInstancePlural}.length > 0">
            <div class="row justify-content-center">
                <jhi-item-count :page="page" :total="queryCount" :itemsPerPage="itemsPerPage"></jhi-item-count>
            </div>
            <div class="row justify-content-center">
                <b-pagination size="md" :total-rows="totalItems" v-model="page" :per-page="itemsPerPage"></b-pagination>
            </div>
        </div>
#end## A-1
#end## A
    </div>
</template>

<script lang="ts" src="./${entityFileName}.component.ts">
</script>
