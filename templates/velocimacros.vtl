        return ${entityInstance}#{if}($viaService)Service.delete#{else}Repository.deleteById#{end}(id)
#if(!$viaService && $searchEngineElasticsearch)## A-1
            .then(${entityInstance}SearchRepository.deleteById(id))
#end## A-1
#if(!$fromResource)## A-2
        ;
#end## A-2
#else## A
        ${entityInstance}#{if}($viaService)Service.delete#{else}Repository.deleteById#{end}(id);
#if(!$viaService && $searchEngineElasticsearch)## A-1
        ${entityInstance}SearchRepository.deleteFromIndexById(id);
#end## A-1
#end## A
#end## A


#macro( _partials_entity_patch_template $isService $viaService $intent = "")## A
#set($instanceType = $restClass)## A
#set($instanceName = $restInstance)## A
#set($returnType = "#if($reactive)Mono#{else}Optional#{end}")## A
#set($mapOrFlatMap = "#if($reactive)flatMap#{else}map#{end}")## A
#set($returnPrefix = "#if($isService)return#{else}${returnType}<${instanceType}> result =#{end}")## A
#set($mapper = $entityInstance + 'Mapper')## A
## 预先计算是否存在非ID非瞬态字段
#set($hasNonIdNonTransientFields = false)## A
#foreach($field in $fields)## A-1
#if(!$field.id && !$field.transient)## A-1-1
#set($hasNonIdNonTransientFields = true)## A-1-1-1
#end## A-1-1
#end## A-1

#if($viaService)## A
  #if($reactive)## A-1
${intent}    Mono<${instanceType}> result = ${entityInstance}Service.partialUpdate(${instanceName});
  #else## A-1
${intent}    Optional<${instanceType}> result = ${entityInstance}Service.partialUpdate(${instanceName});
  #end## A-1
#else## A
${intent}  $returnPrefix ${entityInstance}Repository.findById(${instanceName}.${primaryKey.propertySupplierName}())
  #if($dtoMapstruct || $hasNonIdNonTransientFields)## A-1
${intent}    .map(existing${entityClass} -> {
  #if($dtoMapstruct)## A-1-1
${intent}       ${mapper}.partialUpdate(existing${entityClass}, ${instanceName});
  #else## A-1-1
    #foreach($field in $fields)## A-1-1-1
      #if(!$field.id && !$field.transient)## A-1-1-1-1
${intent}        updateIfPresent(existing${entityClass}::${field.propertyConsumerName}, ${instanceName}.${field.propertySupplierName}());
        #if($field.fieldWithContentType)## A-1-1-1-1-1
${intent}        updateIfPresent(existing${entityClass}::${field.propertyConsumerName}ContentType, ${instanceName}.${field.propertySupplierName}ContentType());
        #end## A-1-1-1-1-1
      #end## A-1-1-1-1
    #end## A-1-1-1
  #end## A-1-1
${intent}    return existing${entityClass};
${intent}    })
  #end## A-1
${intent}  .${mapOrFlatMap}(${entityInstance}Repository::save)
  #if($searchEngineElasticsearch)## A-2
${intent}    .${mapOrFlatMap}(saved${entityClass} -> {
    #if($reactive)## A-2-1
${intent}        ${entityInstance}SearchRepository.save(saved${entityClass});
${intent}        return Mono.just(saved${entityClass});
    #else## A-2-1
${intent}        ${entityInstance}SearchRepository.index(saved${entityClass});
${intent}        return saved${entityClass};
    #end## A-2-1
${intent}      })
  #end## A-2
  #if($dtoMapstruct)## A-3
${intent}   .map(${mapper}::toDto)
  #end## A-3
${intent}  ;
#end## A
#end## A

#macro( _partials_entity_get_filtered_template )## A
#set($instanceType = $restClass)
