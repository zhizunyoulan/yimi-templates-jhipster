#macro( _partials_entity_search_template  $viaService )## A
#set($instanceType = $restClass)##
#set($instanceName = $restInstance)##
#{if}($reactive)
#set($listOrFlux = "Flux")##
#{else}
#set($listOrFlux = "List")##
#{end}
#set($mapper = $entityInstance + 'Mapper')##
#set($entityToDtoReference = $mapper + '::' + 'toDto')##
#set($entityListToDtoListReference = $mapper + '.' + 'toDto')##
#if($paginationNo)## A
    public #{if}($reactive)Mono<#{end}List<${instanceType}>#{if}($reactive)>#{end} search${entityClassPlural}(@RequestParam("query") String query) {
        LOG.debug("REST request to search ${entityClassPlural} for query {}", query);
## 参数：viaService, fromResource
#_partials_entity_search_stream_template($viaService true)
#else## A
    public #{if}($reactive)Mono<#{end}ResponseEntity<${listOrFlux}<${instanceType}>>#{if}($reactive)>#{end} search${entityClassPlural}(@RequestParam("query") String query, @org.springdoc.core.annotations.ParameterObject Pageable pageable#{if}($reactive), ServerHttpRequest request#{end}) {
        LOG.debug("REST request to search for a page of ${entityClassPlural} for query {}", query);
  #if($reactive)## A-1
        return ${entityInstance}#{if}($viaService)Service.#{if}($searchEngineElasticsearch)searchCount#{else}countAll#{end}#{else}#{if}($searchEngineElasticsearch)Search#{end}Repository.count#{end}()
            .map(total -> new PageImpl<>(new ArrayList<>(), pageable, total))
            .map(page -> PaginationUtil.generatePaginationHttpHeaders(ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders()), page))
            .map(headers -> ResponseEntity.ok().headers(headers).body(${entityInstance}#{if}($viaService)Service#{else}#{if}($searchEngineElasticsearch)Search#{end}Repository#{end}.search(query, pageable)#{if}(!$viaService && $dtoMapstruct).map(${entityToDtoReference})#{end}));
  #else## A-1
        try {
    #if($viaService)## A-1-1
            Page<${instanceType}> page = ${entityInstance}Service.search(query, pageable);
    #else## A-1-1
            Page<${persistClass}> page = ${entityInstance}#{if}($searchEngineElasticsearch)Search#{end}Repository.search(query, pageable);
    #end## A-1-1
            HttpHeaders headers = PaginationUtil.generatePaginationHttpHeaders(#{if}($reactive)ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders())#{else}ServletUriComponentsBuilder.fromCurrentRequest()#{end}, page);
            return ResponseEntity.ok().headers(headers).body(#{if}(!$viaService && $dtoMapstruct)${entityListToDtoListReference}(#{end}page.getContent()#{if}(!$viaService && $dtoMapstruct))#{end});
        } catch (RuntimeException e) {
    #if($searchEngineElasticsearch)## A-1-2
            throw ElasticsearchExceptionMapper.mapException(e);
    #else## A-1-2
            throw new RuntimeException(e);
    #end## A-1-2
        }
  #end## A-1
#end## A
    }
#end## A
