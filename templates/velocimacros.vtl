#macro( _partials_entity_get_all_stream_template $viaService )## A
#set($mapper = $entityInstance + 'Mapper')## A
#set($entityToDtoReference = $mapper + '::' + 'toDto')## A
#set($reactiveSql = $databaseTypeSql && $reactive)## A
#set($toResponseEntityPrefix = '')## A
#set($toResponseEntityPostfix = '')## A
#if(!$paginationNo)## A
#if($reactiveSql)## A-1
#set($toResponseEntityPostfix = '.map(ResponseEntity::ok)')## A-1-1
#else## A-1
#set($toResponseEntityPrefix = 'new ResponseEntity<>(')## A-1-1
#set($toResponseEntityPostfix = ', HttpStatus.OK)')## A-1-1
#end## A-1
#end## A
#foreach($relationship in $relationships)## A
#if($relationship.relationshipOneToOne && !$relationship.ownerSide)## A-1
        if ("$relationship.relationshipName.toLowerCase()-is-null".equals(filter)) {
            LOG.debug("REST request to get all ${entityClass}s where ${relationship.relationshipName} is null");
#if($viaService)## A-1-1
            return ${toResponseEntityPrefix}${entityInstance}Service.findAllWhere${relationship.relationshipNameCapitalized}IsNull()#{if}($reactiveSql).collectList()#{end}${toResponseEntityPostfix};
#else## A-1-1
#if($reactiveSql)## A-1-1-1
            return ${toResponseEntityPrefix}${entityInstance}Repository
                .findAllWhere${relationship.relationshipNameCapitalized}IsNull()
#if($dtoMapstruct)## A-1-1-1-1
                .map(${entityToDtoReference})
#end## A-1-1-1-1
                .collectList()${toResponseEntityPostfix};
#elseif($reactive)## A-1-1-1
            return ${toResponseEntityPrefix}${entityInstance}Repository
                .findAll()
                .filter(${entityInstance} -> ${entityInstance}.get${relationship.relationshipNameCapitalized}() == null)
#if($dtoMapstruct)## A-1-1-1-2
                .map(${entityToDtoReference})
#end## A-1-1-1-2
                .collectList()${toResponseEntityPostfix};
#else## A-1-1-1
            return ${toResponseEntityPrefix}StreamSupport
                .stream(${entityInstance}Repository.findAll().spliterator(), false)
                .filter(${entityInstance} -> ${entityInstance}.get${relationship.relationshipNameCapitalized}() == null)
#if($dtoMapstruct)## A-1-1-1-3
                .map(${entityToDtoReference})
#end## A-1-1-1-3
#if(!$paginationNo)## A-1-1-1-4
                .toList(), HttpStatus.OK);
#else## A-1-1-1-4
#if($dtoMapstruct)## A-1-1-1-4-1
                .collect(Collectors.toCollection(LinkedList::new));
#else## A-1-1-1-4-1
                .toList();
#end## A-1-1-1-4-1
#end## A-1-1-1-4
#end## A-1-1-1
#end## A-1-1
        }
#end## A-1
#end## A
#end## A

#macro( _partials_entity_get_all_template $viaService )## A
#set($instanceType = $restClass)## A
#set($instanceName = $restInstance)## A
#set($mapper = $entityInstance + 'Mapper')## A
#set($entityListToDtoListReference = $mapper + '.' + 'toDto')## A
#set($entityToDtoReference = $mapper + '::' + 'toDto')## A
#set($reactiveNoPagination = $reactive && $paginationNo)## A
#set($reactivePagination = $reactive && !$paginationNo)## A
#set($reactiveEntityToDto = "")## A
#if($dtoMapstruct && !$viaService)## A-1
#set($reactiveEntityToDto = ".map(${entityToDtoReference})")## A-1-1
#end## A-1
#if($jpaMetamodelFiltering)## A
    public #{if}($reactiveNoPagination)Flux<${instanceType}>#{elseif}($reactivePagination)Mono<ResponseEntity<List<${instanceType}>>>#{else}ResponseEntity<List<${instanceType}>>#{end} getAll${entityClassPlural}(${entityClass}Criteria criteria#{if}(!$paginationNo), @org.springdoc.core.annotations.ParameterObject Pageable pageable#{if}($reactive), ServerHttpRequest request#{end}#{end}) {
        LOG.debug("REST request to get ${entityClassPlural} by criteria: {}", criteria);
  #if(!$reactive)## A-1
    #if($paginationNo)## A-1-1
        List<${instanceType}> entityList = ${entityInstance}QueryService.findByCriteria(criteria);
        return ResponseEntity.ok().body(entityList);
    #else## A-1-1
        Page<${instanceType}> page = ${entityInstance}QueryService.findByCriteria(criteria, pageable);
        HttpHeaders headers = PaginationUtil.generatePaginationHttpHeaders(#{if}(!$reactive)ServletUriComponentsBuilder.fromCurrentRequest()#{else}ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders())#{end}, page);
        return ResponseEntity.ok().headers(headers).body(page.getContent());
    #end## A-1-1
  #else## A-1
    #if($paginationNo)## A-1-2
      return ${entityInstance}Service.findByCriteria(criteria);
    #else## A-1-2
      return ${entityInstance}#{if}($viaService)Service.countByCriteria#{else}Repository.countByCriteria#{end}(criteria).zipWith(${entityInstance}#{if}($viaService)Service.findByCriteria#{else}Repository.findByCriteria#{end}(criteria, pageable)$reactiveEntityToDto.collectList())
      .map(countWithEntities ->
          ResponseEntity.ok()
              .headers(
                  PaginationUtil.generatePaginationHttpHeaders(
                      ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders()),
                      new PageImpl<>(countWithEntities.getT2(), pageable, countWithEntities.getT1())
                  )
              ).body(countWithEntities.getT2())
      );
    #end## A-1-2
  #end## A-1
    }

    /**
     * {@code GET  /${entityApiUrl}/count} : count all the ${entityInstancePlural}.
     *
     * @param criteria the criteria which the requested entities should match.
     * @return the {@link ResponseEntity} with status {@code 200 (OK)} and the count in body.
     */
    @GetMapping("/count")
    public #{if}($reactive)Mono<#{end}ResponseEntity<Long>#{if}($reactive)>#{end} count${entityClassPlural}(${entityClass}Criteria criteria) {
    #if(!$reactive)## A-1
        LOG.debug("REST request to count ${entityClassPlural} by criteria: {}", criteria);
        return ResponseEntity.ok().body(${entityInstance}QueryService.countByCriteria(criteria));
    #else## A-1
        LOG.debug("REST request to count ${entityClassPlural} by criteria: {}", criteria);
        return ${entityInstance}Service.countByCriteria(criteria)
                .map(count -> ResponseEntity.status(HttpStatus.OK).body(count));
    #end## A-1
    }
#else## A
  #if($paginationNo)## A-1
    public #{if}($reactive)Mono<#{end}List<${instanceType}>#{if}($reactive)>#{end} getAll${entityClassPlural}(#{if}($fieldsContainNoOwnerOneToOne)@RequestParam(name = "filter", required = false) String filter#{end}#{if}($implementsEagerLoadApis && $fieldsContainNoOwnerOneToOne),#{end}#{if}($implementsEagerLoadApis)@RequestParam(name = "eagerload", required = false, defaultValue = "true") boolean eagerload#{end}) {
## 参数：viaService
#_partials_entity_get_all_stream_template($viaService)
        LOG.debug("REST request to get all ${entityClassPlural}");
    #if($viaService)## A-1-1
        return ${entityInstance}Service.findAll()#{if}($reactive).collectList()#{end};
    #elseif($dtoMapstruct)## A-1-1
        ${emptyStr}#{if}($reactive)Flux#{else}List#{end}<${persistClass}> ${entityInstancePlural} = ${entityInstance}Repository.findAll();
      #if($reactive)## A-1-1-1
        return ${entityInstancePlural}.map(${entityToDtoReference}).collectList();
      #else## A-1-1-1
        return ${entityListToDtoListReference}(${entityInstancePlural});
      #end## A-1-1-1
    #elseif($implementsEagerLoadApis)## A-1-1
        if (eagerload) {
            return ${entityInstance}Repository.findAllWithEagerRelationships()#{if}($reactive).collectList()#{end};
        } else {
            return ${entityInstance}Repository.findAll()#{if}($reactive).collectList()#{end};
        }
    #else## A-1-1
            return ${entityInstance}Repository.findAll()#{if}($reactive).collectList()#{end};
    #end## A-1-1
  #else## A-1
    public #{if}($reactive)Mono<ResponseEntity<List<${instanceType}>>>#{else}ResponseEntity<List<${instanceType}>>#{end} getAll${entityClassPlural}(@org.springdoc.core.annotations.ParameterObject Pageable pageable#{if}($reactive), ServerHttpRequest request#{end}#{if}($fieldsContainNoOwnerOneToOne), @RequestParam(name = "filter", required = false) String filter#{end}#{if}($implementsEagerLoadApis), @RequestParam(name = "eagerload", required = false, defaultValue = "true") boolean eagerload#{end}) {
## 参数：viaService
#_partials_entity_get_all_stream_template($viaService)
        LOG.debug("REST request to get a page of ${entityClassPlural}");
    #if($reactive)## A-1-2
        return ${entityInstance}#{if}($viaService)Service.countAll#{else}Repository.count#{end}().zipWith(${entityInstance}#{if}($viaService)Service.findAll#{else}Repository.findAllBy#{end}(pageable)$reactiveEntityToDto.collectList())
                .map(countWithEntities ->
                    ResponseEntity.ok()
                        .headers(
                            PaginationUtil.generatePaginationHttpHeaders(
                                ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders()),
                                new PageImpl<>(countWithEntities.getT2(), pageable, countWithEntities.getT1())
                            )
                        ).body(countWithEntities.getT2())
                );
    #else## A-1-2
      #if($implementsEagerLoadApis)## A-1-2-1
        Page<${instanceType}> page;
        if (eagerload) {
            page = ${entityInstance}#{if}($viaService)Service#{else}Repository#{end}.findAllWithEagerRelationships(pageable)$reactiveEntityToDto;
        } else {
            page = ${entityInstance}#{if}($viaService)Service#{else}Repository#{end}.findAll(pageable)$reactiveEntityToDto;
        }
        HttpHeaders headers = PaginationUtil.generatePaginationHttpHeaders(#{if}($reactive)ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders())#{else}ServletUriComponentsBuilder.fromCurrentRequest()#{end}, page);
      #else## A-1-2-1
        Page<${instanceType}> page = ${entityInstance}#{if}($viaService)Service#{else}Repository#{end}.findAll(pageable)$reactiveEntityToDto;
        HttpHeaders headers = PaginationUtil.generatePaginationHttpHeaders(#{if}($reactive)ForwardedHeaderUtils.adaptFromForwardedHeaders(request.getURI(), request.getHeaders())#{else}ServletUriComponentsBuilder.fromCurrentRequest()#{end}, page);
      #end## A-1-2-1
        return ResponseEntity.ok().headers(headers).body(page.getContent());
    #end## A-1-2
  #end## A-1
    }
#end## A
#end## A



#macro( _partials_entity_get_template $viaService $returnDirectly $implementsEagerLoadApis )## A
