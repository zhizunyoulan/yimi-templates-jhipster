        return ${entityInstance}Repository
            .findAll()
            .filter(${entityInstance} -> ${entityInstance}.${relationship.propertySupplierName}() == null)
      #if($dtoMapstruct)## A-1-2-1
            .map(${entityToDtoReference})
      #end## A-1-2-1
            ;
#else## A-1-2
        return StreamSupport
            .stream(${entityInstance}Repository.findAll().spliterator(), false)
            .filter(${entityInstance} -> ${entityInstance}.${relationship.propertySupplierName}() == null)
      #if($dtoMapstruct)## A-1-2-1
            .map(${entityToDtoReference})
            .collect(Collectors.toCollection(LinkedList::new));
      #else## A-1-2-1
            .toList();
      #end## A-1-2-1
#end## A-1-2
    }
#end## A-1
#end## A
#end## A

