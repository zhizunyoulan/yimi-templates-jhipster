#macro( _global_partials_entity_save_template $saveNewEntityOperation $returnDirectly $intent = "" )## A
#if($dtoMapstruct)## A
${intent}        ${persistClass} ${persistInstance} = ${entityInstance}Mapper.toEntity(${restInstance});
#end## A
#if(!$saveNewEntityOperation && $requiresPersistableImplementation)## A
${intent}        ${persistInstance}.setIsPersisted();
#end## A
#if($saveNewEntityOperation && $isUsingMapsId)## A
${intent}        ${mapsIdAssoc.otherEntity.primaryKey.type} ${mapsIdAssoc.otherEntityName}Id = ${persistInstance}.${mapsIdAssoc.propertySupplierName}().${mapsIdAssoc.otherEntity.primaryKey.propertySupplierName}();
${intent}        ${mapsIdAssoc.otherEntity.entityInstance}Repository.findById(${mapsIdAssoc.otherEntityName}Id).ifPresent(${persistInstance}::#{if}(!$fluentMethods)${mapsIdAssoc.propertyConsumerName}#{else}${mapsIdAssoc.relationshipName}#{end});
#end## A
#{if}($returnDirectly && !$searchEngineElasticsearch && !$dtoMapstruct)
#set($tempReturn = "return")
#{else}
#set($tempReturn = "${persistInstance} =")
#{end}
${intent}        $tempReturn ${entityInstance}Repository.save(${persistInstance});
#if($searchEngineElasticsearch)## A
${intent}        ${entityInstance}SearchRepository.index(${persistInstance});
#end## A
#if($dtoMapstruct)## A
${intent}        #{if}($returnDirectly)return#{else}${dtoInstance} =#{end} ${entityInstance}Mapper.toDto(${persistInstance});
#elseif($returnDirectly && $searchEngineElasticsearch)## A
${intent}        return ${persistInstance};
#end## A
#end## A


#macro( _partials_entity_delete_template $viaService $fromResource )## A
