        <variable type="Primitive">
          <property>searchEngine</property>
          <label>SearchEngine</label>
          <javaType>String</javaType>
          <defaultValue>elasticsearch</defaultValue>
          <inputType>select</inputType>
          <options>
            <option label="elasticsearch" value="elasticsearch"/>
