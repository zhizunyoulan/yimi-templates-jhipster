          <inputType>select</inputType>
          <options>
            <option label="en" value="en"/>
            <option label="zh-cn" value="zh-cn"/>
          </options>
          <designVisible>false</designVisible>
        </variable>
        <variable type="Primitive">
          <property>prodDatabaseType</property>
          <label>ProdDatabaseType</label>
