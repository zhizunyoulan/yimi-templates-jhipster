<config>
  <templates location="backend">
    <template>
      <id>BACKEND_MODEL</id>
      <sourcePath>backend/src/main/java/__base_package__/model/__modelName__.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/domain/__modelName__.java</targetPath>
      <modelBound>true</modelBound>
    </template>
    <template>
      <id>BACKEND_ENTITY_ID_CLASS</id>
      <sourcePath>backend/src/main/java/__base_package__/model/__modelName__IdClass.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/domain/__modelName__IdClass.java</targetPath>
      <modelBound>true</modelBound>
      <condition>currentModel.fields.count { it.primaryKey } > 1</condition>
    </template>
    <template>
      <id>BACKEND_READ_RESULT_DTO</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/dto/_dtoClass_.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/dto/__modelName__DTO.java</targetPath>
      <modelBound>true</modelBound>
      <condition>resultModelClass?.classType == "DTO"</condition>
    </template>
    <template>
      <id>BACKEND_READ_RESULT_INTERFACE</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/dto/I__modelName__.java.vm
      </sourcePath>
      <targetPath>src/main/java/__base_package__/domain/I__modelName__.java</targetPath>
      <condition>resultModelClass?.classType == 'Interface'</condition>
    </template>
    <template>
      <id>BACKEND_READ_RESULT_RECORD</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/dto/__modelName__Record.java.vm
      </sourcePath>
      <targetPath>src/main/java/__base_package__/domain/__modelName__Record.java</targetPath>
      <condition>resultModelClass?.classType == 'Record'</condition>
    </template>
    <template>
      <id>BACKEND_READ_REQUEST_DTO</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/criteria/_entityClass_Criteria.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/criteria/__modelName__Criteria.java</targetPath>
      <condition>requestModelClass?.classType == 'DTO'</condition>
    </template>

    <template>
      <id>BACKEND_REPOSITORY</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_Repository.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__Repository.java</targetPath>
      <condition>!global.reactive</condition>
    </template>

    <template>
      <id>BACKEND_REPOSITORY_WITH_BAG_RELATIONSHIPS</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_RepositoryWithBagRelationships.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__RepositoryWithBagRelationships.java</targetPath>
      <condition>!global.reactive && currentModel.fields.any { it.nestInfo != null && it.nestInfo.type == "collection" }</condition>
    </template>
    <template>
      <id>BACKEND_REPOSITORY_WITH_BAG_RELATIONSHIPS_IMPL</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_RepositoryWithBagRelationshipsImpl.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__RepositoryWithBagRelationshipsImpl.java</targetPath>
      <condition>!global.reactive && currentModel.fields.any { it.nestInfo != null && it.nestInfo.type == "collection" }</condition>
    </template>

    <template>
      <id>BACKEND_REPOSITORY_REACTIVE</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_Repository_reactive.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__Repository.java</targetPath>
      <condition>global.reactive && !global.entityR2dbcRepository</condition>
    </template>
    <template>
      <id>BACKEND_REPOSITORY_INTERNALIMPL_REACTIVE</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_RepositoryInternalImpl_reactive.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__RepositoryInternalImpl.java</targetPath>
      <condition>global.reactive && !global.entityR2dbcRepository</condition>
    </template>
    <template>
      <id>BACKEND_SQLHELPER_REACTIVE</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_SqlHelper_reactive.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__SqlHelper.java</targetPath>
      <condition>global.reactive && !global.entityR2dbcRepository</condition>
    </template>
    <template>
      <id>BACKEND_ROWMAPPER_REACTIVE</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/rowmapper/_entityClass_RowMapper_reactive.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/rowmapper/__modelName__RowMapper.java</targetPath>
      <condition>global.reactive && !global.entityR2dbcRepository</condition>
    </template>

    <template>
      <id>BACKEND_REPOSITORY_R2DBC</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/relational/repository/_entityClass_Repository_r2dbc.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/repository/__modelName__Repository.java</targetPath>
      <condition>global.reactive && global.entityR2dbcRepository</condition>
    </template>

    <template>
      <id>BACKEND_SEARCH_REPOSITORY</id>
      <sourcePath>spring-boot/src/main/java/_package_/data/elasticsearch/repository/_entityClass_SearchRepository.java.vm
      </sourcePath>
      <targetPath>src/main/java/__base_package__/repository/search/__modelName__SearchRepository.java</targetPath>
      <condition>global.searchEngine == 'elasticsearch'</condition>
    </template>
    <template>
      <id>BACKEND_MAPPER</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/mapper/_entityClass_Mapper.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/mapper/__modelName__Mapper.java</targetPath>
      <condition>resultModelClass?.classType == 'DTO' && global.service == 'no'</condition>
    </template>
    <template>
      <id>BACKEND_QUERY_SERVICE</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/_entityClass_QueryService.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/__modelName__QueryService.java</targetPath>
      <condition>readDefinition != null && !readDefinition.conditionFields.isEmpty() && !global.reactive</condition>
    </template>
    <template>
      <id>BACKEND_SERVICE_INTERFACE</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/_entityClass_Service.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/__modelName__Service.java</targetPath>
      <condition>global.service == 'serviceImpl'</condition>
    </template>
    <template>
      <id>BACKEND_SERVICE_IMPL</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/impl/_entityClass_ServiceImpl.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/impl/__modelName__ServiceImpl.java</targetPath>
      <condition>global.service == 'serviceImpl'</condition>
    </template>
    <template>
      <id>BACKEND_SERVICE</id>
      <sourcePath>spring-boot/src/main/java/_package_/service/impl/_entityClass_ServiceImpl.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/service/__modelName__Service.java</targetPath>
      <condition>global.service == 'serviceClass'</condition>
    </template>
    <template>
      <id>BACKEND_CONTROLLER</id>
      <sourcePath>spring-boot/src/main/java/_package_/web/rest/_entityClass_Resource.java.vm</sourcePath>
      <targetPath>src/main/java/__base_package__/web/rest/__modelName__Resource.java</targetPath>
    </template>



  </templates>

  <templates location="frontend">
    <profile id="admin" label="Admin" device="desktop" baseDir="src\main\webapp">
      <template>
        <id>FRONTEND_SERVICE_TS</id>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_.service.ts.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__.service.ts</targetPath>
      </template>
      <template>
        <id>FRONTEND_MODEL_TS</id>
        <sourcePath>client/_vue/app/shared/model/_entityModel_.model.ts.vm</sourcePath>
        <targetPath>app/shared/model/__kebabCaseModelName__.model.ts</targetPath>
      </template>
      <template>
        <id>FRONTEND_COMPONENT_TS</id>
        <condition>readDefinition != null</condition>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_.component.ts.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__.component.ts</targetPath>
      </template>
      <template>
        <id>FRONTEND_LIST_VIEW</id>
        <condition>readDefinition != null</condition>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_.vue.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__.vue</targetPath>
      </template>
      <template>
        <id>FRONTEND_UPDATE_COMPONENT_TS</id>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_-update.component.ts.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__-update.component.ts</targetPath>
        <condition>readOnly == false</condition>
      </template>
      <template>
        <id>FRONTEND_UPDATE_VIEW</id>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_-update.vue.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__-update.vue</targetPath>
        <condition>readOnly == false</condition>
      </template>
      <template>
        <id>FRONTEND_DETAILS_COMPONENT_TS</id>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_-details.component.ts.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__-details.component.ts</targetPath>
      </template>
      <template>
        <id>FRONTEND_DETAILS_VIEW</id>
        <sourcePath>client/_vue/app/entities/_entityFolder_/_entityFile_-details.vue.vm</sourcePath>
        <targetPath>app/entities/__kebabCaseModelName__/__kebabCaseModelName__-details.vue</targetPath>
      </template>
      <template>
        <id>FRONTEND_ROUTER_ENTITIES</id>
        <condition>readDefinition != null</condition>
        <sourcePath>client/_vue/app/router/entities.ts.vm</sourcePath>
        <targetPath>app/router/entities.ts</targetPath>
      </template>
    </profile>
  </templates>


  <basePackage>__groupId__</basePackage>
  <databaseFramework>JPA</databaseFramework>
  <custom-variables>
    <variable type="Object">
      <property>readDefinition</property>
      <label>ReadDefinition</label>
      <sub-variables>
        <variable type="FieldList">
          <property>selectFields</property>
          <label>SelectFields</label>
          <sortable>true</sortable>
        </variable>
        <variable type="FieldList">
          <property>conditionFields</property>
          <label>ConditionFields</label>
          <sortable>true</sortable>
        </variable>
        <variable type="Primitive">
          <property>paginate</property>
          <label>Paginate</label>
          <javaType>String</javaType>
          <defaultValue>no</defaultValue>
          <inputType>select</inputType>
          <options>
            <option label="pagination" value="pagination"/>
            <option label="infinite-scroll" value="infinite-scroll"/>
            <option label="no" value="no"/>
          </options>
        </variable>
      </sub-variables>
    </variable>
    <variable type="Object">
      <property>createDefinition</property>
      <label>CreateDefinition</label>
      <sub-variables>
        <variable type="FieldList">
          <property>formFields</property>
          <label>FormFields</label>
        </variable>
      </sub-variables>
    </variable>
    <variable type="Object">
      <property>updateDefinition</property>
      <label>UpdateDefinition</label>
      <sub-variables>
        <variable type="FieldList">
          <property>formFields</property>
          <label>FormFields</label>
        </variable>
      </sub-variables>
    </variable>
    <variable type="Object">
      <property>deleteDefinition</property>
      <label>DeleteDefinition</label>
      <sub-variables/>
    </variable>
    <variable type="Object">
      <property>fieldDefinition</property>
      <label>FieldDefinition</label>
      <sub-variables>
        <variable type="Object">
          <property>selectProperties</property>
          <label>SelectProperties</label>
          <sub-variables>
            <variable type="Primitive">
              <property>relationshipRequired</property>
              <label>Required</label>
              <javaType>Boolean</javaType>
              <defaultValue>false</defaultValue>
            </variable>
          </sub-variables>
          <display-locations>
            <location>readDefinition.selectFields</location>
          </display-locations>
        </variable>
        <variable type="Object">
          <property>conditionProperties</property>
          <label>ConditionProperties</label>
          <sub-variables/>
          <display-locations>
            <location>readDefinition.conditionFields</location>
          </display-locations>
        </variable>
        <variable type="Object">
          <property>formProperties</property>
          <label>FormProperties</label>
          <sub-variables/>
          <display-locations>
            <location>createDefinition.formFields</location>
            <location>updateDefinition.formFields</location>
          </display-locations>
        </variable>
      </sub-variables>
    </variable>
    <variable type="Object">
      <property>global</property>
      <label>Global</label>
      <sub-variables>
        <variable type="Primitive">
          <property>applicationType</property>
          <label>ApplicationType</label>
          <javaType>String</javaType>
          <defaultValue>monolith</defaultValue>
          <inputType>select</inputType>
          <options>
            <option label="monolith" value="monolith"/>
            <option label="microservice" value="microservice"/>
            <option label="gateway" value="gateway"/>
          </options>
          <designVisible>false</designVisible>
        </variable>
        <variable type="Primitive">
          <property>authenticationType</property>
          <label>AuthenticationType</label>
          <javaType>String</javaType>
          <defaultValue>jwt</defaultValue>
          <inputType>select</inputType>
          <options>
            <option label="jwt" value="jwt"/>
            <option label="session" value="session"/>
            <option label="oauth2" value="oauth2"/>
          </options>
          <designVisible>false</designVisible>
        </variable>
        <variable type="Primitive">
          <property>baseName</property>
          <label>BaseName</label>
          <javaType>String</javaType>
          <inputType>input</inputType>
          <designVisible>false</designVisible>
        </variable>
        <variable type="Primitive">
          <property>cacheProvider</property>
          <label>CacheProvider</label>
          <javaType>String</javaType>
          <defaultValue>ehcache</defaultValue>
          <inputType>select</inputType>
          <options>
            <option label="caffeine" value="caffeine"/>
            <option label="ehcache" value="ehcache"/>
            <option label="hazelcast" value="hazelcast"/>
            <option label="infinispan" value="infinispan"/>
            <option label="memcached" value="memcached"/>
            <option label="redis" value="redis"/>
            <option label="no" value="no"/>
          </options>
          <designVisible>false</designVisible>
        </variable>
        <variable type="Primitive">
          <property>databaseType</property>
          <label>DatabaseType</label>
          <javaType>String</javaType>
          <defaultValue>sql</defaultValue>
          <inputType>select</inputType>
          <options>
            <option label="sql" value="sql"/>
            <option label="mongodb" value="mongodb"/>
            <option label="cassandra" value="cassandra"/>
            <option label="couchbase" value="couchbase"/>
            <option label="no" value="no"/>
          </options>
          <designVisible>false</designVisible>
        </variable>
        <variable type="Primitive">
